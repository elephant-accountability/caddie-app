{
  "expo": {
    "name": "Caddie",
    "slug": "caddie",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "caddie",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121216"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ealegalllc.caddie",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Caddie uses the microphone to record voice notes about customer interactions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#121216"
      },
      "package": "com.ealegalllc.caddie",
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Caddie uses the microphone to record voice notes about customer interactions."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3B82F6"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://caddie-core.fly.dev",
      "eas": {
        "projectId": ""
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
