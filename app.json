{
  "expo": {
    "name": "Caddie EDC",
    "slug": "caddie-edc",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "caddie-edc",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121216"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.elephantaccountability.caddie",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Caddie EDC uses the microphone to record voice notes about customer interactions.",
        "LSApplicationQueriesSchemes": [
          "googlegmail", "ms-outlook", "hubspot", "salesforce1",
          "apollo", "closeapp", "salesloft", "googledrive",
          "ms-onedrive", "dbapi-1", "boxnet", "slack",
          "msteams", "whatsapp", "tg", "zoomus",
          "granola", "otter", "fireflies", "calendly",
          "comgooglemaps", "waze", "linkedin"
        ]
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#121216"
      },
      "package": "com.elephantaccountability.caddie",
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Caddie EDC uses the microphone to record voice notes about customer interactions."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3B82F6"
        }
      ],
      "expo-sqlite",
      "./plugins/callkit/withCallKit",
      [
        "expo-share-extension",
        {
          "activationRules": [
            { "type": "text" },
            { "type": "url", "max": 1 },
            { "type": "image", "max": 3 },
            { "type": "file", "max": 3 }
          ],
          "excludedPackages": [
            "expo-dev-client",
            "expo-splash-screen",
            "expo-updates",
            "expo-font"
          ]
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://caddie-core.fly.dev",
      "vapiPublicKey": "46d95a26-6cd4-4aa6-8776-0f9c6f1f5cde",
      "eas": {
        "projectId": "346f6991-d682-44e3-aad8-6341b1fddc34"
      },
      "router": {}
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "chris-caddieedc"
  }
}
