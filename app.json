{
  "expo": {
    "name": "Caddie",
    "slug": "caddie",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "caddie",
    "splash": {
      "backgroundColor": "#0A0F1C"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.eallc.caddie",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Caddie uses the microphone to log touches by voice."
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3B82F6"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}